# ─────────────────────────────────────────────────────────────
# AidBridge AI — Environment Configuration
# Copy this file to `.env.local` and fill in what you have.
# The app is FULLY USABLE with NO keys (demo mode is the default).
# The app never crashes on missing env vars — anything unset falls back safely.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME=AidBridge AI
NEXT_PUBLIC_ORG_NAME=Community Response Collective
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# AI provider (vendor-neutral).
#   AI_PROVIDER: "demo" | "live"
#   AI_DEMO_MODE=true forces deterministic mock AI even if a live endpoint is set.
# The live path targets ANY chat-completions-compatible endpoint you choose —
# no specific vendor is named or assumed. If unset/failed, it falls back to demo.
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=demo
AI_DEMO_MODE=true

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# ─────────────────────────────────────────────────────────────
# Supabase (optional — the app runs on the in-memory demo store if unset)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
