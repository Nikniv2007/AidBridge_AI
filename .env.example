# ─────────────────────────────────────────────────────────────
# AidBridge AI — Environment Configuration
# Copy this file to `.env.local` and fill in what you have.
# The app is FULLY USABLE with NO keys (demo mode is the default).
# ─────────────────────────────────────────────────────────────

# AI provider selection: "live" | "demo"
# If the live endpoint/key is not configured, the app falls back to demo mode.
AI_PROVIDER=demo

# Force deterministic mock AI even when a live endpoint is configured. "true" | "false"
AI_DEMO_MODE=true

# Live LLM endpoint (optional — only needed for live AI mode).
# Point this at any chat-completions-compatible endpoint of your choice.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# ─────────────────────────────────────────────────────────────
# Supabase (optional — the app runs on in-memory mock data if unset)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# App configuration
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AidBridge AI
NEXT_PUBLIC_ORG_NAME=Community Response Collective
